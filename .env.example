# Optional telemetry. Leave empty for local development and most forks.
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=

# Optional updater override for local release builds.
# Prefer UPDATER_OWNER_REPO for GitHub-hosted forks.
UPDATER_OWNER_REPO=
UPDATER_ENDPOINT=
UPDATER_RELEASE_PAGE=

# Release signing keys belong in GitHub Actions secrets, not in this file:
# TAURI_SIGNING_PRIVATE_KEY
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD

