{
  "name": "codex-clone-launcher",
  "private": false,
  "description": "Tauri desktop launcher for isolated Codex Desktop clones with explicit sync-package repair.",
  "version": "0.24.13",
  "license": "MIT",
  "keywords": [
    "codex",
    "tauri",
    "desktop",
    "launcher",
    "profile-manager",
    "sync-package"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yq6666-66/codex-clone-launcher.git"
  },
  "homepage": "https://github.com/yq6666-66/codex-clone-launcher#readme",
  "bugs": {
    "url": "https://github.com/yq6666-66/codex-clone-launcher/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run typecheck",
    "build": "npm run sync-version && tsc && vite build",
    "verify": "npm run typecheck && npm run build && npm run test:rust && npm run verify:ui-regression && npm run verify:ui-workflows && npm run verify:release-workflow && npm run verify:windows-shortcut",
    "verify:ui-regression": "node scripts/verify-ui-regression.cjs",
    "verify:ui-workflows": "node scripts/verify-ui-workflows.cjs",
    "verify:windows-shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-windows-shortcut.ps1",
    "verify:updater-release": "node scripts/verify-updater-release.cjs",
    "verify:release-workflow": "node scripts/verify-release-workflow.cjs",
    "test:rust": "node scripts/cargo-test-workspace.cjs",
    "preview": "vite preview",
    "pretauri:dev": "npm run typecheck",
    "tauri:dev": "node scripts/tauri-dev.cjs",
    "pretauri": "npm run typecheck",
    "tauri": "npm run sync-version && tauri",
    "sync-version": "node scripts/sync-version.js"
  },
  "dependencies": {
    "@sentry/react": "^10.55.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.14",
    "date-fns": "^4.1.0",
    "i18next": "^25.7.4",
    "lucide-react": "^0.562.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.3",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.23",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^8.0.16"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "rollup": "4.59.0"
  },
  "engines": {
    "node": ">=20"
  }
}
