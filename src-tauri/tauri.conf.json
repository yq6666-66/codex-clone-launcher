{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex \u5206\u8eab\u542f\u52a8\u5668",
  "version": "0.24.7",
  "identifier": "com.jlcodes.codex-clone-launcher",
  "build": {
    "beforeDevCommand": "node scripts/prepare-tauri.cjs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/prepare-tauri.cjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Codex \u5206\u8eab\u542f\u52a8\u5668",
        "width": 1220,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/48x48.png",
      "icons/32x32.png",
      "icons/16x16.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src/assets/icons/codex.svg": "native-menu-icons/codex.svg"
    }
  }
}
